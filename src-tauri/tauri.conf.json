{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Viber Balance",
  "version": "0.1.1",
  "identifier": "site.claudegateway.viber.balance",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "popup",
        "url": "index.html",
        "title": "Viber Balance",
        "width": 320,
        "height": 310,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
